  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_order = {\n    'Significant Decline': 0,\n    'Declined': 1,\n    'Slight Decline': 2,\n    'No Change': 3,\n    'Slight Improvement': 4,\n    'Improved': 5,\n    'Significant Improvement': 6\n}\n\nsatisfaction_order = {\n    'Low': 0,\n    'Medium': 1,\n    'High': 2\n}\n\ndf['Impact_Score'] = df['Impact_on_Grades'].map(impact_order)\ndf['Satisfaction_Score'] = df['Satisfaction_Level'].map(satisfaction_order)\n\nsame_time_pairs = []\nn = len(df)\n\nfor i in range(n):\n    for j in range(i + 1, n):\n        h1 = df.loc[i, 'Daily_Usage_Hours']\n        h2 = df.loc[j, 'Daily_Usage_Hours']\n        s1 = df.loc[i, 'Impact_Score']\n        s2 = df.loc[j, 'Impact_Score']\n        if pd.notna(s1) and pd.notna(s2):\n            if abs(h1 - h2) <= 0.2 and abs(s1 - s2) >= 2:\n                row1 = df.loc[i]\n                row2 = df.loc[j]\n                differing_factors = []\n                for col in ['Purpose', 'AI_Tool_Used', 'Satisfaction_Level', 'Education_Level', 'City', 'Gender', 'Age']:\n                    if row1[col] != row2[col]:\n                        differing_factors.append(col)\n                same_time_pairs.append({\n                    'student_1_id': int(row1['Student_ID']),\n                    'student_2_id': int(row2['Student_ID']),\n                    'student_1_usage_hours': float(row1['Daily_Usage_Hours']),\n                    'student_2_usage_hours': float(row2['Daily_Usage_Hours']),\n                    'student_1_impact': row1['Impact_on_Grades'],\n                    'student_2_impact': row2['Impact_on_Grades'],\n                    'possible_explanatory_factors': differing_factors,\n                    'student_1_profile': {\n                        'Age': int(row1['Age']),\n                        'Gender': row1['Gender'],\n                        'Education_Level': row1['Education_Level'],\n                        'City': row1['City'],\n                        'AI_Tool_Used': row1['AI_Tool_Used'],\n                        'Purpose': row1['Purpose'],\n                        'Satisfaction_Level': row1['Satisfaction_Level']\n                    },\n                    'student_2_profile': {\n                        'Age': int(row2['Age']),\n                        'Gender': row2['Gender'],\n                        'Education_Level': row2['Education_Level'],\n                        'City': row2['City'],\n                        'AI_Tool_Used': row2['AI_Tool_Used'],\n                        'Purpose': row2['Purpose'],\n                        'Satisfaction_Level': row2['Satisfaction_Level']\n                    },\n                    'impact_gap': int(abs(s1 - s2))\n                })\n\nsame_time_pairs = sorted(same_time_pairs, key=lambda x: (-x['impact_gap'], abs(x['student_1_usage_hours'] - x['student_2_usage_hours'])))\n\nfactor_counts = {}\nfor pair in same_time_pairs:\n    for f in pair['possible_explanatory_factors']:\n        factor_counts[f] = factor_counts.get(f, 0) + 1\n\nresult = {\n    'matched_pairs_count': len(same_time_pairs),\n    'examples': same_time_pairs[:10],\n    'most_common_possible_factors': dict(sorted(factor_counts.items(), key=lambda x: (-x[1], x[0]))),\n    'summary': (\n        'Students were matched when their Daily_Usage_Hours were very similar (within 0.2 hours) '\n        'but their Impact_on_Grades differed substantially. Possible explanations are based on '\n        'differences in Purpose, AI_Tool_Used, Satisfaction_Level, Education_Level, City, Gender, and Age. '\n        'In this dataset, differences in how students use AI (Purpose), which tool they use, and their '\n        'Satisfaction_Level are plausible factors behind different academic outcomes despite similar usage time.'\n    )\n}",
