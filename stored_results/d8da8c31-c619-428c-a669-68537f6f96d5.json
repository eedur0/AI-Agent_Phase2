  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_score_map = {\n    'Significantly Improved': 3,\n    'Improved': 2,\n    'No Change': 1,\n    'Slight Decline': 0,\n    'Declined': -1\n}\nsatisfaction_score_map = {\n    'High': 3,\n    'Medium': 2,\n    'Low': 1\n}\n\ndf['impact_score'] = df['Impact_on_Grades'].map(impact_score_map).fillna(0)\ndf['satisfaction_score'] = df['Satisfaction_Level'].map(satisfaction_score_map).fillna(0)\n\ngroup_cols = ['Education_Level', 'Purpose', 'AI_Tool_Used']\n\ngrouped = df.groupby(group_cols).agg(\n    student_count=('Student_ID', 'count'),\n    avg_impact_score=('impact_score', 'mean'),\n    improved_rate=('Impact_on_Grades', lambda x: float(((x == 'Improved') | (x == 'Significantly Improved')).mean())),\n    avg_satisfaction_score=('satisfaction_score', 'mean'),\n    avg_daily_usage_hours=('Daily_Usage_Hours', 'mean'),\n    avg_age=('Age', 'mean')\n).reset_index()\n\ngrouped['performance_score'] = (\n    grouped['avg_impact_score'] * 0.6 +\n    grouped['improved_rate'] * 2.5 +\n    grouped['avg_satisfaction_score'] * 0.4\n)\n\ntop5 = grouped.sort_values(\n    by=['performance_score', 'avg_impact_score', 'improved_rate', 'student_count'],\n    ascending=[False, False, False, False]\n).head(5).copy()\n\ndef explain_row(row):\n    factors = []\n    if row['avg_impact_score'] >= 2:\n        factors.append('consistently positive grade impact')\n    elif row['avg_impact_score'] >= 1.5:\n        factors.append('above-average positive grade impact')\n    if row['improved_rate'] >= 0.75:\n        factors.append('very high share of students reporting improved grades')\n    elif row['improved_rate'] >= 0.5:\n        factors.append('majority of students reporting improved grades')\n    if row['avg_satisfaction_score'] >= 2.5:\n        factors.append('high satisfaction with AI tool usage')\n    elif row['avg_satisfaction_score'] >= 2:\n        factors.append('solid satisfaction levels')\n    if row['avg_daily_usage_hours'] >= df['Daily_Usage_Hours'].median():\n        factors.append('relatively strong daily engagement with AI tools')\n    else:\n        factors.append('efficient AI usage without excessive time investment')\n    return ', '.join(factors)\n\ntop5['explanation'] = top5.apply(explain_row, axis=1)\n\nresult = top5[[\n    'Education_Level',\n    'Purpose',\n    'AI_Tool_Used',\n    'student_count',\n    'avg_impact_score',\n    'improved_rate',\n    'avg_satisfaction_score',\n    'avg_daily_usage_hours',\n    'performance_score',\n    'explanation'\n]].round({\n    'avg_impact_score': 3,\n    'improved_rate': 3,\n    'avg_satisfaction_score': 3,\n    'avg_daily_usage_hours': 3,\n    'performance_score': 3\n}).to_dict(orient='records')",
