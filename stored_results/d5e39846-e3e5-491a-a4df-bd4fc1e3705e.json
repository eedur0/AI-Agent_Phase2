  "follow_up_context": "",
  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_order = {\n    'Significant Decline': 1,\n    'Declined': 2,\n    'Slight Decline': 3,\n    'No Change': 4,\n    'Slight Improvement': 5,\n    'Improved': 6,\n    'Significant Improvement': 7\n}\n\ndf = df.copy()\ndf['Impact_Score'] = df['Impact_on_Grades'].map(impact_order)\n\n# Compare students with very similar study/usage time (same rounded daily usage hours to 0.1)\ngroup_col = 'Daily_Usage_Hours'\npairs = []\n\nfor usage_value, grp in df.groupby(group_col):\n    grp = grp.dropna(subset=['Impact_Score'])\n    if len(grp) < 2:\n        continue\n    grp = grp.sort_values('Impact_Score')\n    low = grp.iloc[0]\n    high = grp.iloc[-1]\n    diff = int(high['Impact_Score'] - low['Impact_Score'])\n    if diff >= 2:  # significant difference in academic outcome\n        differing_factors = {}\n        compare_cols = [\n            'Age', 'Gender', 'Education_Level', 'City',\n            'AI_Tool_Used', 'Purpose', 'Satisfaction_Level'\n        ]\n        for col in compare_cols:\n            if low[col] != high[col]:\n                differing_factors[col] = {\n                    'lower_performance_student': low[col].item() if hasattr(low[col], 'item') else low[col],\n                    'higher_performance_student': high[col].item() if hasattr(high[col], 'item') else high[col]\n                }\n        pairs.append({\n            'Daily_Usage_Hours': float(usage_value),\n            'lower_performance_student': {\n                'Student_ID': int(low['Student_ID']),\n                'Impact_on_Grades': str(low['Impact_on_Grades'])\n            },\n            'higher_performance_student': {\n                'Student_ID': int(high['Student_ID']),\n                'Impact_on_Grades': str(high['Impact_on_Grades'])\n            },\n            'impact_score_gap': diff,\n            'possible_explanatory_factors': differing_factors\n        })\n\npairs = sorted(pairs, key=lambda x: (-x['impact_score_gap'], x['Daily_Usage_Hours']))\n\nsummary_factors = {}\nfor p in pairs:\n    for k in p['possible_explanatory_factors'].keys():\n        summary_factors[k] = summary_factors.get(k, 0) + 1\n\nsummary_factors = dict(sorted(summary_factors.items(), key=lambda x: (-x[1], x[0])))\n\nresult = {\n    'students_with_similar_study_time_but_different_performance': pairs,\n    'likely_explanatory_factors_summary': summary_factors,\n    'interpretation': (\n        \"Students with the same Daily_Usage_Hours can still report different Impact_on_Grades. \"\n        \"The differences are most plausibly associated with how they use AI (Purpose), which AI tool they use, \"\n        \"their Satisfaction_Level, and contextual differences such as Education_Level, Age, Gender, or City. \"\n        \"Because the dataset does not include direct study-time or GPA values, Daily_Usage_Hours is used as the closest proxy for similar study time, \"\n        \"and Impact_on_Grades is used as the academic performance indicator.\"\n    )\n}",
