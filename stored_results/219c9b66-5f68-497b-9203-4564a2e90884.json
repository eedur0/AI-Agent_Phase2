  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(csv_path)\n\n# Create income bins to find areas with similar median income\ndf[\"income_bin\"] = pd.qcut(df[\"median_income\"], q=8, duplicates=\"drop\")\n\n# Aggregate by ocean proximity within each income bin\ngrouped = (\n    df.groupby([\"income_bin\", \"ocean_proximity\"], observed=False)\n    .agg(\n        median_income=(\"median_income\", \"median\"),\n        median_house_value=(\"median_house_value\", \"median\"),\n        housing_median_age=(\"housing_median_age\", \"median\"),\n        population=(\"population\", \"median\"),\n        households=(\"households\", \"median\"),\n        total_rooms=(\"total_rooms\", \"median\"),\n        latitude=(\"latitude\", \"median\"),\n        longitude=(\"longitude\", \"median\"),\n        count=(\"median_house_value\", \"size\"),\n    )\n    .reset_index()\n)\n\n# For each income bin, identify pairs with large house-value differences\npairs = []\nfor income_bin, g in grouped.groupby(\"income_bin\", observed=False):\n    g = g.sort_values(\"median_house_value\").reset_index(drop=True)\n    if len(g) < 2:\n        continue\n    min_row = g.iloc[0]\n    max_row = g.iloc[-1]\n    value_diff = float(max_row[\"median_house_value\"] - min_row[\"median_house_value\"])\n    income_diff = float(abs(max_row[\"median_income\"] - min_row[\"median_income\"]))\n    if value_diff >= 100000 and income_diff <= 0.5:\n        pairs.append({\n            \"income_bin\": str(income_bin),\n            \"lower_value_area\": min_row[\"ocean_proximity\"],\n            \"higher_value_area\": max_row[\"ocean_proximity\"],\n            \"median_income_lower\": round(float(min_row[\"median_income\"]), 3),\n            \"median_income_higher\": round(float(max_row[\"median_income\"]), 3),\n            \"median_house_value_lower\": round(float(min_row[\"median_house_value\"]), 0),\n            \"median_house_value_higher\": round(float(max_row[\"median_house_value\"]), 0),\n            \"house_value_gap\": round(value_diff, 0),\n            \"housing_age_lower\": round(float(min_row[\"housing_median_age\"]), 1),\n            \"housing_age_higher\": round(float(max_row[\"housing_median_age\"]), 1),\n            \"population_lower\": round(float(min_row[\"population\"]), 1),\n            \"population_higher\": round(float(max_row[\"population\"]), 1),\n            \"latitude_lower\": round(float(min_row[\"latitude\"]), 3),\n            \"latitude_higher\": round(float(max_row[\"latitude\"]), 3),\n            \"longitude_lower\": round(float(min_row[\"longitude\"]), 3),\n            \"longitude_higher\": round(float(max_row[\"longitude\"]), 3),\n            \"count_lower\": int(min_row[\"count\"]),\n            \"count_higher\": int(max_row[\"count\"]),\n        })\n\n# Sort by the largest gap and keep the strongest examples\npairs = sorted(pairs, key=lambda x: x[\"house_value_gap\"], reverse=True)[:5]\n\n# Add concise interpretation\nfor p in pairs:\n    factors = []\n    if (\"NEAR OCEAN\" in [p[\"higher_value_area\"], p[\"lower_value_area\"]] or\n        \"NEAR BAY\" in [p[\"higher_value_area\"], p[\"lower_value_area\"]] or\n        \"ISLAND\" in [p[\"higher_value_area\"], p[\"lower_value_area\"]]):\n        factors.append(\"coastal or bay proximity likely raises prices even when incomes are similar\")\n    if abs(p[\"housing_age_higher\"] - p[\"housing_age_lower\"]) >= 8:\n        factors.append(\"differences in housing stock age may reflect more established or more desirable neighborhoods\")\n    if abs(p[\"population_higher\"] - p[\"population_lower\"]) >= 300:\n        factors.append(\"different neighborhood density/population levels may affect desirability and pricing\")\n    if not factors:\n        factors.append(\"location-related amenities and neighborhood desirability likely explain much of the gap\")\n    p[\"possible_explanations\"] = factors\n\nresult = {\n    \"identified_comparisons\": pairs,\n    \"summary\": (\n        \"Areas with similar median income but very different median house values are most often separated by \"\n        \"ocean/bay proximity and broader location desirability. Coastal and bay-adjacent areas tend to have \"\n        \"substantially higher home values than inland areas with comparable incomes. Differences in housing age, \"\n        \"density, and local neighborhood characteristics may also contribute.\"\n    )\n}",
