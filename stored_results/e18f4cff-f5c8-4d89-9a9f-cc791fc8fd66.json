  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(csv_path)\n\n# Create geographic bins based on latitude and longitude ranges\nlat_bins = np.arange(np.floor(df[\"latitude\"].min()), np.ceil(df[\"latitude\"].max()) + 0.5, 0.5)\nlon_bins = np.arange(np.floor(df[\"longitude\"].min()), np.ceil(df[\"longitude\"].max()) + 0.5, 0.5)\n\ndf[\"latitude_range\"] = pd.cut(df[\"latitude\"], bins=lat_bins, include_lowest=True)\ndf[\"longitude_range\"] = pd.cut(df[\"longitude\"], bins=lon_bins, include_lowest=True)\n\ngrouped = (\n    df.groupby([\"latitude_range\", \"longitude_range\"], observed=False)[\"median_house_value\"]\n    .agg([\"mean\", \"count\"])\n    .reset_index()\n    .sort_values([\"mean\", \"count\"], ascending=[False, False])\n)\n\ntop_groups = grouped.head(10).copy()\n\ndef interval_to_range(interval):\n    if pd.isna(interval):\n        return None\n    return {\n        \"min\": float(interval.left),\n        \"max\": float(interval.right)\n    }\n\nresult = [\n    {\n        \"latitude_range\": interval_to_range(row[\"latitude_range\"]),\n        \"longitude_range\": interval_to_range(row[\"longitude_range\"]),\n        \"average_house_price\": float(row[\"mean\"]),\n        \"num_records\": int(row[\"count\"])\n    }\n    for _, row in top_groups.iterrows()\n]",
