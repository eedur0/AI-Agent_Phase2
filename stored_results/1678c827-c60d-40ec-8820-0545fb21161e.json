  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(csv_path)\n\ncoastal = df[df[\"ocean_proximity\"].isin([\"NEAR OCEAN\", \"<1H OCEAN\", \"NEAR BAY\"])].copy()\n\ngroup_cols = [\"ocean_proximity\", \"longitude\", \"latitude\"]\narea_stats = (\n    coastal.groupby(group_cols)\n    .agg(\n        median_house_value=(\"median_house_value\", \"median\"),\n        median_income=(\"median_income\", \"median\"),\n        housing_median_age=(\"housing_median_age\", \"median\"),\n        population=(\"population\", \"median\"),\n        households=(\"households\", \"median\"),\n        total_rooms=(\"total_rooms\", \"median\"),\n        total_bedrooms=(\"total_bedrooms\", \"median\"),\n        count=(\"median_house_value\", \"size\"),\n    )\n    .reset_index()\n)\n\ncoastal_median = float(coastal[\"median_house_value\"].median())\ncoastal_income_median = float(coastal[\"median_income\"].median())\n\nlow_price_areas = area_stats[\n    area_stats[\"median_house_value\"] <= area_stats[\"median_house_value\"].quantile(0.25)\n].copy()\n\nlow_price_areas[\"rooms_per_household\"] = low_price_areas[\"total_rooms\"] / low_price_areas[\"households\"].replace(0, np.nan)\nlow_price_areas[\"bedrooms_per_room\"] = low_price_areas[\"total_bedrooms\"] / low_price_areas[\"total_rooms\"].replace(0, np.nan)\nlow_price_areas[\"population_per_household\"] = low_price_areas[\"population\"] / low_price_areas[\"households\"].replace(0, np.nan)\nlow_price_areas[\"price_vs_coastal_median\"] = low_price_areas[\"median_house_value\"] / coastal_median\nlow_price_areas[\"income_vs_coastal_median\"] = low_price_areas[\"median_income\"] / coastal_income_median\n\nlow_price_areas = low_price_areas.sort_values(\n    [\"median_house_value\", \"median_income\", \"count\"],\n    ascending=[True, True, False]\n)\n\ntop_areas = low_price_areas.head(10).copy()\n\nareas_list = []\nfor _, row in top_areas.iterrows():\n    factors = []\n    if row[\"median_income\"] < coastal_income_median:\n        factors.append(\"lower median income\")\n    if row[\"population_per_household\"] > low_price_areas[\"population_per_household\"].median():\n        factors.append(\"higher crowding/population per household\")\n    if row[\"bedrooms_per_room\"] > low_price_areas[\"bedrooms_per_room\"].median():\n        factors.append(\"higher bedroom share of rooms (potentially smaller/denser units)\")\n    if row[\"housing_median_age\"] < coastal[\"housing_median_age\"].median():\n        factors.append(\"relatively newer housing stock\")\n    if row[\"count\"] == 1:\n        factors.append(\"single-record area; interpret cautiously\")\n\n    areas_list.append({\n        \"ocean_proximity\": row[\"ocean_proximity\"],\n        \"longitude\": float(row[\"longitude\"]),\n        \"latitude\": float(row[\"latitude\"]),\n        \"median_house_value\": float(row[\"median_house_value\"]),\n        \"median_income\": float(row[\"median_income\"]),\n        \"count\": int(row[\"count\"]),\n        \"price_vs_coastal_median\": float(round(row[\"price_vs_coastal_median\"], 3)),\n        \"population_per_household\": None if pd.isna(row[\"population_per_household\"]) else float(round(row[\"population_per_household\"], 3)),\n        \"bedrooms_per_room\": None if pd.isna(row[\"bedrooms_per_room\"]) else float(round(row[\"bedrooms_per_room\"], 3)),\n        \"possible_explanatory_factors\": factors\n    })\n\nsummary = {\n    \"coastal_categories_used\": [\"NEAR OCEAN\", \"<1H OCEAN\", \"NEAR BAY\"],\n    \"coastal_median_house_value\": coastal_median,\n    \"coastal_median_income\": coastal_income_median,\n    \"method\": \"Grouped coastal tracts by exact longitude/latitude and selected the bottom quartile of coastal median_house_value as relatively low-priced coastal areas.\",\n    \"low_priced_coastal_areas\": areas_list,\n    \"overall_explanation\": [\n        \"Across coastal categories, relatively low house prices tend to coincide with lower median_income.\",\n        \"Some low-priced coastal areas also show higher population per household, suggesting crowding or lower housing quality.\",\n        \"Higher bedrooms_per_room can indicate denser/smaller homes, which may reduce prices despite coastal proximity.\",\n        \"Ocean proximity alone does not guarantee high prices; local income, density, and housing characteristics still matter.\"\n    ]\n}\n\nresult = summary",
