  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_order = {\n    'Significant Decline': 0,\n    'Slight Decline': 1,\n    'No Change': 2,\n    'Improved': 3,\n    'Significantly Improved': 4\n}\n\ndf['Impact_Score'] = df['Impact_on_Grades'].map(impact_order)\n\n# Group students by similar daily usage time (rounded to nearest 0.5 hour)\ndf['Usage_Bin'] = (df['Daily_Usage_Hours'] * 2).round() / 2\n\npairs = []\nfor usage_bin, group in df.groupby('Usage_Bin'):\n    if group['Impact_Score'].nunique() > 1:\n        low = group.loc[group['Impact_Score'].idxmin()]\n        high = group.loc[group['Impact_Score'].idxmax()]\n        if high['Impact_Score'] - low['Impact_Score'] >= 2:\n            differing_factors = {}\n            for col in ['Purpose', 'AI_Tool_Used', 'Satisfaction_Level', 'Education_Level', 'Age', 'Gender', 'City']:\n                if low[col] != high[col]:\n                    differing_factors[col] = {\n                        'lower_performance_student': low[col].item() if hasattr(low[col], 'item') else low[col],\n                        'higher_performance_student': high[col].item() if hasattr(high[col], 'item') else high[col]\n                    }\n\n            pairs.append({\n                'Daily_Usage_Hours_Bin': float(usage_bin),\n                'lower_performance_student': {\n                    'Student_ID': int(low['Student_ID']),\n                    'Impact_on_Grades': low['Impact_on_Grades'],\n                    'Daily_Usage_Hours': float(low['Daily_Usage_Hours']),\n                    'Purpose': low['Purpose'],\n                    'AI_Tool_Used': low['AI_Tool_Used'],\n                    'Satisfaction_Level': low['Satisfaction_Level'],\n                    'Education_Level': low['Education_Level'],\n                    'Age': int(low['Age']),\n                    'Gender': low['Gender'],\n                    'City': low['City']\n                },\n                'higher_performance_student': {\n                    'Student_ID': int(high['Student_ID']),\n                    'Impact_on_Grades': high['Impact_on_Grades'],\n                    'Daily_Usage_Hours': float(high['Daily_Usage_Hours']),\n                    'Purpose': high['Purpose'],\n                    'AI_Tool_Used': high['AI_Tool_Used'],\n                    'Satisfaction_Level': high['Satisfaction_Level'],\n                    'Education_Level': high['Education_Level'],\n                    'Age': int(high['Age']),\n                    'Gender': high['Gender'],\n                    'City': high['City']\n                },\n                'possible_explanatory_factors': differing_factors\n            })\n\n# Summarize broad patterns in factors among all contrasting pairs\nfactor_patterns = {}\nfor factor in ['Purpose', 'AI_Tool_Used', 'Satisfaction_Level', 'Education_Level', 'Age', 'Gender', 'City']:\n    diffs = []\n    for p in pairs:\n        if factor in p['possible_explanatory_factors']:\n            diffs.append(p['possible_explanatory_factors'][factor])\n    if diffs:\n        factor_patterns[factor] = diffs\n\nresult = {\n    'similar_study_time_different_performance': pairs,\n    'summary': (\n        'Students with similar Daily_Usage_Hours can show very different Impact_on_Grades. '\n        'The most plausible explanatory factors in this dataset are differences in Purpose, '\n        'AI_Tool_Used, Satisfaction_Level, and Education_Level; demographic/context variables '\n        'such as Age, Gender, and City may also contribute.'\n    ),\n    'factor_patterns': factor_patterns\n}",
