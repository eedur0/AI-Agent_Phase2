  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_order = {\n    'Significant Decline': 0,\n    'Slight Decline': 1,\n    'No Change': 2,\n    'Improved': 3,\n    'Significantly Improved': 4\n}\n\ndf = df.copy()\ndf['Impact_Score'] = df['Impact_on_Grades'].map(impact_order)\n\n# Find students with similar study time (Daily_Usage_Hours within 0.3 hours)\n# but significantly different academic performance (impact score difference >= 2)\npairs = []\nn = len(df)\n\nfor i in range(n):\n    for j in range(i + 1, n):\n        usage_diff = abs(df.loc[i, 'Daily_Usage_Hours'] - df.loc[j, 'Daily_Usage_Hours'])\n        score_i = df.loc[i, 'Impact_Score']\n        score_j = df.loc[j, 'Impact_Score']\n        if pd.notna(score_i) and pd.notna(score_j):\n            perf_diff = abs(score_i - score_j)\n            if usage_diff <= 0.3 and perf_diff >= 2:\n                row_i = df.loc[i]\n                row_j = df.loc[j]\n                differing_factors = []\n                for col in ['Age', 'Gender', 'Education_Level', 'City', 'AI_Tool_Used', 'Purpose', 'Satisfaction_Level']:\n                    if row_i[col] != row_j[col]:\n                        differing_factors.append(col)\n                pairs.append({\n                    'Student_1_ID': int(row_i['Student_ID']),\n                    'Student_2_ID': int(row_j['Student_ID']),\n                    'Student_1_Daily_Usage_Hours': float(row_i['Daily_Usage_Hours']),\n                    'Student_2_Daily_Usage_Hours': float(row_j['Daily_Usage_Hours']),\n                    'Student_1_Impact_on_Grades': row_i['Impact_on_Grades'],\n                    'Student_2_Impact_on_Grades': row_j['Impact_on_Grades'],\n                    'Usage_Hours_Difference': float(round(usage_diff, 2)),\n                    'Performance_Gap': int(perf_diff),\n                    'Potential_Explaining_Factors': differing_factors,\n                    'Student_1_Profile': {\n                        'Age': int(row_i['Age']),\n                        'Gender': row_i['Gender'],\n                        'Education_Level': row_i['Education_Level'],\n                        'City': row_i['City'],\n                        'AI_Tool_Used': row_i['AI_Tool_Used'],\n                        'Purpose': row_i['Purpose'],\n                        'Satisfaction_Level': row_i['Satisfaction_Level']\n                    },\n                    'Student_2_Profile': {\n                        'Age': int(row_j['Age']),\n                        'Gender': row_j['Gender'],\n                        'Education_Level': row_j['Education_Level'],\n                        'City': row_j['City'],\n                        'AI_Tool_Used': row_j['AI_Tool_Used'],\n                        'Purpose': row_j['Purpose'],\n                        'Satisfaction_Level': row_j['Satisfaction_Level']\n                    }\n                })\n\npairs_df = pd.DataFrame(pairs)\n\n# Summarize most common differing factors across identified pairs\nfactor_counts = {}\nfor p in pairs:\n    for f in p['Potential_Explaining_Factors']:\n        factor_counts[f] = factor_counts.get(f, 0) + 1\n\nfactor_counts = dict(sorted(factor_counts.items(), key=lambda x: (-x[1], x[0])))\n\nresult = {\n    'students_with_similar_study_time_but_different_performance': pairs[:20],\n    'number_of_matching_pairs': int(len(pairs)),\n    'most_common_potential_explaining_factors': factor_counts,\n    'summary': (\n        'Students were matched when their Daily_Usage_Hours differed by 0.3 hours or less, '\n        'but their Impact_on_Grades differed by at least two levels. Potential explanations '\n        'are based on differences in Age, Gender, Education_Level, City, AI_Tool_Used, Purpose, '\n        'and Satisfaction_Level between matched students.'\n    )\n}",
