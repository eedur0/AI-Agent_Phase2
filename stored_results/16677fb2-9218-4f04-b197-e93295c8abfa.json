  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_score_map = {\n    'Improved': 3,\n    'No Change': 2,\n    'Slight Decline': 1,\n    'Declined': 0\n}\nsatisfaction_score_map = {\n    'High': 3,\n    'Medium': 2,\n    'Low': 1\n}\n\ndf['impact_score'] = df['Impact_on_Grades'].map(impact_score_map)\ndf['satisfaction_score'] = df['Satisfaction_Level'].map(satisfaction_score_map)\n\ngroup_cols = ['Education_Level', 'Purpose']\n\ngrouped = df.groupby(group_cols).agg(\n    student_count=('Student_ID', 'count'),\n    avg_impact_score=('impact_score', 'mean'),\n    improved_rate=('Impact_on_Grades', lambda x: (x == 'Improved').mean()),\n    avg_satisfaction_score=('satisfaction_score', 'mean'),\n    avg_daily_usage_hours=('Daily_Usage_Hours', 'mean')\n).reset_index()\n\ngrouped['performance_score'] = (\n    grouped['avg_impact_score'] * 0.6 +\n    grouped['improved_rate'] * 3 * 0.3 +\n    grouped['avg_satisfaction_score'] * 0.1\n)\n\ntop5 = grouped.sort_values(\n    by=['performance_score', 'avg_impact_score', 'improved_rate', 'avg_satisfaction_score', 'student_count'],\n    ascending=[False, False, False, False, False]\n).head(5).copy()\n\nexplanations = []\nfor _, row in top5.iterrows():\n    factors = []\n    if row['avg_impact_score'] >= grouped['avg_impact_score'].mean():\n        factors.append('strong positive grade impact')\n    if row['improved_rate'] >= grouped['improved_rate'].mean():\n        factors.append('high share of students reporting improved grades')\n    if row['avg_satisfaction_score'] >= grouped['avg_satisfaction_score'].mean():\n        factors.append('above-average satisfaction with AI tools')\n    if row['avg_daily_usage_hours'] >= grouped['avg_daily_usage_hours'].mean():\n        factors.append('relatively high daily AI usage')\n    else:\n        factors.append('efficient AI usage without excessive time')\n    explanations.append({\n        'Education_Level': row['Education_Level'],\n        'Purpose': row['Purpose'],\n        'student_count': int(row['student_count']),\n        'performance_score': round(float(row['performance_score']), 3),\n        'avg_impact_score': round(float(row['avg_impact_score']), 3),\n        'improved_rate': round(float(row['improved_rate']), 3),\n        'avg_satisfaction_score': round(float(row['avg_satisfaction_score']), 3),\n        'avg_daily_usage_hours': round(float(row['avg_daily_usage_hours']), 3),\n        'key_factors': factors\n    })\n\nresult = explanations",
