  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(csv_path)\n\ncoastal = df[df[\"ocean_proximity\"].isin([\"NEAR OCEAN\", \"<1H OCEAN\", \"NEAR BAY\"])].copy()\n\ncoastal[\"rooms_per_household\"] = coastal[\"total_rooms\"] / coastal[\"households\"].replace(0, np.nan)\ncoastal[\"bedrooms_per_room\"] = coastal[\"total_bedrooms\"] / coastal[\"total_rooms\"].replace(0, np.nan)\ncoastal[\"population_per_household\"] = coastal[\"population\"] / coastal[\"households\"].replace(0, np.nan)\n\ncoastal_summary = coastal.groupby(\"ocean_proximity\").agg(\n    count=(\"median_house_value\", \"size\"),\n    median_house_value_mean=(\"median_house_value\", \"mean\"),\n    median_house_value_median=(\"median_house_value\", \"median\"),\n    median_income_mean=(\"median_income\", \"mean\"),\n    housing_median_age_mean=(\"housing_median_age\", \"mean\"),\n    population_mean=(\"population\", \"mean\"),\n    households_mean=(\"households\", \"mean\"),\n    rooms_per_household_mean=(\"rooms_per_household\", \"mean\"),\n    bedrooms_per_room_mean=(\"bedrooms_per_room\", \"mean\"),\n    population_per_household_mean=(\"population_per_household\", \"mean\"),\n).reset_index()\n\nlow_price_threshold = coastal[\"median_house_value\"].quantile(0.25)\nlow_price_coastal = coastal[coastal[\"median_house_value\"] <= low_price_threshold].copy()\n\nlocation_summary = (\n    low_price_coastal.groupby([\"ocean_proximity\", \"longitude\", \"latitude\"])\n    .agg(\n        count=(\"median_house_value\", \"size\"),\n        mean_house_value=(\"median_house_value\", \"mean\"),\n        median_income_mean=(\"median_income\", \"mean\"),\n        housing_median_age_mean=(\"housing_median_age\", \"mean\"),\n        population_mean=(\"population\", \"mean\"),\n        households_mean=(\"households\", \"mean\"),\n        rooms_per_household_mean=(\"rooms_per_household\", \"mean\"),\n        bedrooms_per_room_mean=(\"bedrooms_per_room\", \"mean\"),\n        population_per_household_mean=(\"population_per_household\", \"mean\"),\n    )\n    .reset_index()\n    .sort_values([\"mean_house_value\", \"count\"], ascending=[True, False])\n)\n\ntop_locations = location_summary.head(10).copy()\n\ncoastal_means = coastal[[\n    \"median_house_value\",\n    \"median_income\",\n    \"housing_median_age\",\n    \"population\",\n    \"households\",\n    \"rooms_per_household\",\n    \"bedrooms_per_room\",\n    \"population_per_household\"\n]].mean(numeric_only=True)\n\nlow_price_means = low_price_coastal[[\n    \"median_house_value\",\n    \"median_income\",\n    \"housing_median_age\",\n    \"population\",\n    \"households\",\n    \"rooms_per_household\",\n    \"bedrooms_per_room\",\n    \"population_per_household\"\n]].mean(numeric_only=True)\n\ncomparison = pd.DataFrame({\n    \"coastal_mean\": coastal_means,\n    \"low_price_coastal_mean\": low_price_means\n})\ncomparison[\"difference\"] = comparison[\"low_price_coastal_mean\"] - comparison[\"coastal_mean\"]\n\nfactors = []\nif comparison.loc[\"median_income\", \"difference\"] < 0:\n    factors.append(\"Lower median income than other coastal areas\")\nif comparison.loc[\"population_per_household\", \"difference\"] > 0:\n    factors.append(\"Higher population density / crowding per household\")\nif comparison.loc[\"bedrooms_per_room\", \"difference\"] > 0:\n    factors.append(\"Higher bedroom-to-room ratio, suggesting smaller or more crowded housing\")\nif comparison.loc[\"rooms_per_household\", \"difference\"] < 0:\n    factors.append(\"Fewer rooms per household on average\")\nif comparison.loc[\"housing_median_age\", \"difference\"] < 0:\n    factors.append(\"Slightly newer housing stock, which may reflect less established or less desirable neighborhoods\")\nelif comparison.loc[\"housing_median_age\", \"difference\"] > 0:\n    factors.append(\"Older housing stock in some cheaper coastal tracts\")\n\nresult = {\n    \"coastal_area_summary_by_proximity\": coastal_summary.round(3).to_dict(orient=\"records\"),\n    \"low_price_threshold_for_coastal_areas\": float(low_price_threshold),\n    \"example_low_price_coastal_locations\": top_locations.round(3).to_dict(orient=\"records\"),\n    \"factor_comparison_low_price_vs_all_coastal\": comparison.round(3).reset_index().rename(columns={\"index\": \"metric\"}).to_dict(orient=\"records\"),\n    \"possible_explanations\": factors\n}",
