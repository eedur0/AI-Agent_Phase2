tool usage shown in the summaries.\"\n)\n\nresult = {\n    'definition_used': {\n        'low_daily_usage_hours_threshold': float(low_hours_threshold),\n        'high_stress_proxy': 'Satisfaction_Level = Low and/or Impact_on_Grades = Slight Decline'\n    },\n    'students': students,\n    'possible_explanatory_factors': factor_summaries,\n    'explanation': explanation\n}",
