le\":{\"x\":0.05},\"mapbox\":{\"style\":\"light\"}}},\"xaxis\":{\"anchor\":\"y\",\"domain\":[0.0,1.0],\"title\":{\"text\":\"Median income\"},\"zeroline\":false},\"yaxis\":{\"anchor\":\"x\",\"domain\":[0.0,1.0],\"title\":{\"text\":\"Median house value ($)\"},\"tickformat\":\"$,.0f\",\"zeroline\":false},\"legend\":{\"title\":{\"text\":\"Area type\"},\"tracegroupgap\":0,\"itemsizing\":\"constant\",\"orientation\":\"h\",\"yanchor\":\"top\",\"y\":-0.22,\"xanchor\":\"center\",\"x\":0.5},\"title\":{\"text\":\"Similar Income, Different House Value\\u003cbr\\u003e\\u003csup\\u003eComparing records within the same median_income bins shows that location-related categories (especially ocean_proximity) can have large differences in median_house_value even when incomes are similar. Areas closer to the coast or bay often have much higher house values than inland areas with comparable incomes. Likely explanations include stronger location desirability, limited coastal housing supply, access to jobs and amenities, and neighborhood effects not captured by income alone. Differences in housing_median_age, density, population, and household patterns may also contribute, but ocean proximity appears to be a major driver.\\u003c\\u002fsup\\u003e\",\"x\":0.5,\"xanchor\":\"center\"},\"annotations\":[{\"arrowhead\":2,\"ax\":20,\"ay\":-20,\"bgcolor\":\"rgba(255,255,255,0.8)\",\"bordercolor\":\"rgba(80,80,80,0.4)\",\"font\":{\"size\":11},\"showarrow\":true,\"text\":\"INLAND\",\"x\":2.754,\"y\":98100},{\"arrowhead\":2,\"ax\":20,\"ay\":-20,\"bgcolor\":\"rgba(255,255,255,0.8)\",\"bordercolor\":\"rgba(80,80,80,0.4)\",\"font\":{\"size\":11},\"showarrow\":true,\"text\":\"ISLAND\",\"x\":2.833,\"y\":414700},{\"arrowhead\":2,\"ax\":20,\"ay\":-20,\"bgcolor\":\"rgba(255,255,255,0.8)\",\"bordercolor\":\"rgba(80,80,80,0.4)\",\"font\":{\"size\":11},\"showarrow\":true,\"text\":\"\\u003c1H OCEAN\",\"x\":2.773,\"y\":170400},{\"arrowhead\":2,\"ax\":20,\"ay\":-20,\"bgcolor\":\"rgba(255,255,255,0.8)\",\"bordercolo