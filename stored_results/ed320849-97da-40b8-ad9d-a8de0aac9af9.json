  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(csv_path)\n\n# Create income bins to compare areas with similar median income\ndf = df.copy()\ndf[\"income_bin\"] = pd.qcut(df[\"median_income\"], q=8, duplicates=\"drop\")\n\n# Aggregate by ocean proximity within income bins\ngrouped = (\n    df.groupby([\"income_bin\", \"ocean_proximity\"], observed=False)\n    .agg(\n        count=(\"median_house_value\", \"size\"),\n        median_income=(\"median_income\", \"median\"),\n        median_house_value=(\"median_house_value\", \"median\"),\n        housing_median_age=(\"housing_median_age\", \"median\"),\n        total_rooms=(\"total_rooms\", \"median\"),\n        total_bedrooms=(\"total_bedrooms\", \"median\"),\n        population=(\"population\", \"median\"),\n        households=(\"households\", \"median\"),\n    )\n    .reset_index()\n)\n\n# Find pairs within the same income bin that have large house value differences\npairs = []\nfor income_bin, sub in grouped.groupby(\"income_bin\", observed=False):\n    sub = sub.reset_index(drop=True)\n    if len(sub) < 2:\n        continue\n    for i in range(len(sub)):\n        for j in range(i + 1, len(sub)):\n            a = sub.loc[i]\n            b = sub.loc[j]\n            value_diff = abs(a[\"median_house_value\"] - b[\"median_house_value\"])\n            income_diff = abs(a[\"median_income\"] - b[\"median_income\"])\n            if value_diff >= 75000 and income_diff <= 0.35:\n                pairs.append({\n                    \"income_bin\": str(income_bin),\n                    \"area_1\": a[\"ocean_proximity\"],\n                    \"area_2\": b[\"ocean_proximity\"],\n                    \"area_1_median_income\": round(float(a[\"median_income\"]), 3),\n                    \"area_2_median_income\": round(float(b[\"median_income\"]), 3),\n                    \"area_1_median_house_value\": int(round(a[\"median_house_value\"])),\n                    \"area_2_median_house_value\": int(round(b[\"median_house_value\"])),\n                    \"house_value_difference\": int(round(value_diff)),\n                    \"area_1_housing_median_age\": round(float(a[\"housing_median_age\"]), 1),\n                    \"area_2_housing_median_age\": round(float(b[\"housing_median_age\"]), 1),\n                    \"area_1_population\": int(round(a[\"population\"])),\n                    \"area_2_population\": int(round(b[\"population\"])),\n                    \"area_1_households\": int(round(a[\"households\"])),\n                    \"area_2_households\": int(round(b[\"households\"])),\n                })\n\npairs_df = pd.DataFrame(pairs).sort_values(\n    by=[\"house_value_difference\", \"area_1_median_income\"], ascending=[False, True]\n)\n\ntop_examples = pairs_df.head(8).to_dict(orient=\"records\") if not pairs_df.empty else []\n\n# Supporting overall medians by ocean proximity\noverall_by_area = (\n    df.groupby(\"ocean_proximity\", observed=False)\n    .agg(\n        count=(\"median_house_value\", \"size\"),\n        median_income=(\"median_income\", \"median\"),\n        median_house_value=(\"median_house_value\", \"median\"),\n        housing_median_age=(\"housing_median_age\", \"median\"),\n        population=(\"population\", \"median\"),\n        households=(\"households\", \"median\"),\n    )\n    .reset_index()\n)\n\noverall_by_area[\"count\"] = overall_by_area[\"count\"].astype(int)\noverall_by_area[\"median_income\"] = overall_by_area[\"median_income\"].round(3)\noverall_by_area[\"median_house_value\"] = overall_by_area[\"median_house_value\"].round(0).astype(int)\noverall_by_area[\"housing_median_age\"] = overall_by_area[\"housing_median_age\"].round(1)\noverall_by_area[\"population\"] = overall_by_area[\"population\"].round(0).astype(int)\noverall_by_area[\"households\"] = overall_by_area[\"households\"].round(0).astype(int)\n\nexplanation = (\n    \"Comparing records within the same median_income bins shows that location-related categories \"\n    \"(especially ocean_proximity) can have large differences in median_house_value even when incomes are similar. \"\n    \"Areas closer to the coast or bay often have much higher house values than inland areas with comparable incomes. \"\n    \"Likely explanations include stronger location desirability, limited coastal housing supply, access to jobs and amenities, \"\n    \"and neighborhood effects not captured by income alone. Differences in housing_median_age, density, population, and \"\n    \"household patterns may also contribute, but ocean proximity appears to be a major driver.\"\n)\n\nresult = {\n    \"similar_income_different_value_examples\": top_examples,\n    \"overall_medians_by_ocean_proximity\": overall_by_area.to_dict(orient=\"records\"),\n    \"explanation\": explanation\n}",
