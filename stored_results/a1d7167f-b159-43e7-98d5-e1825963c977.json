  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv(csv_path)\n\nimpact_score_map = {\n    \"Improved\": 2,\n    \"No Change\": 1,\n    \"Slight Decline\": 0\n}\nsatisfaction_score_map = {\n    \"High\": 2,\n    \"Medium\": 1,\n    \"Low\": 0\n}\n\ndf[\"impact_score\"] = df[\"Impact_on_Grades\"].map(impact_score_map)\ndf[\"satisfaction_score\"] = df[\"Satisfaction_Level\"].map(satisfaction_score_map)\n\ngroup_cols = [\"Education_Level\", \"Purpose\"]\n\ngrouped = (\n    df.groupby(group_cols)\n    .agg(\n        student_count=(\"Student_ID\", \"count\"),\n        avg_impact_score=(\"impact_score\", \"mean\"),\n        improved_rate=(\"Impact_on_Grades\", lambda x: (x == \"Improved\").mean()),\n        avg_satisfaction_score=(\"satisfaction_score\", \"mean\"),\n        high_satisfaction_rate=(\"Satisfaction_Level\", lambda x: (x == \"High\").mean()),\n        avg_daily_usage_hours=(\"Daily_Usage_Hours\", \"mean\"),\n        top_ai_tool=(\"AI_Tool_Used\", lambda x: x.mode().iloc[0] if not x.mode().empty else None)\n    )\n    .reset_index()\n)\n\ngrouped[\"performance_score\"] = (\n    grouped[\"avg_impact_score\"] * 0.6 +\n    grouped[\"improved_rate\"] * 0.25 +\n    grouped[\"avg_satisfaction_score\"] / 2 * 0.15\n)\n\ntop5 = grouped.sort_values(\n    by=[\"performance_score\", \"avg_impact_score\", \"improved_rate\", \"student_count\"],\n    ascending=[False, False, False, False]\n).head(5).copy()\n\ndef explain_row(row):\n    factors = []\n    if row[\"avg_impact_score\"] >= 1.5:\n        factors.append(\"strong positive grade impact\")\n    if row[\"improved_rate\"] >= 0.5:\n        factors.append(f\"high improvement rate ({row['improved_rate']:.0%})\")\n    if row[\"avg_satisfaction_score\"] >= 1.0:\n        factors.append(\"good satisfaction with AI tools\")\n    factors.append(f\"average daily usage of {row['avg_daily_usage_hours']:.2f} hours\")\n    if pd.notna(row[\"top_ai_tool\"]):\n        factors.append(f\"most-used AI tool: {row['top_ai_tool']}\")\n    return \", \".join(factors)\n\ntop5[\"explanation\"] = top5.apply(explain_row, axis=1)\n\nresult = top5[\n    [\n        \"Education_Level\",\n        \"Purpose\",\n        \"student_count\",\n        \"performance_score\",\n        \"avg_impact_score\",\n        \"improved_rate\",\n        \"avg_satisfaction_score\",\n        \"high_satisfaction_rate\",\n        \"avg_daily_usage_hours\",\n        \"top_ai_tool\",\n        \"explanation\"\n    ]\n].round(\n    {\n        \"performance_score\": 3,\n        \"avg_impact_score\": 3,\n        \"improved_rate\": 3,\n        \"avg_satisfaction_score\": 3,\n        \"high_satisfaction_rate\": 3,\n        \"avg_daily_usage_hours\": 3\n    }\n).to_dict(orient=\"records\")",
