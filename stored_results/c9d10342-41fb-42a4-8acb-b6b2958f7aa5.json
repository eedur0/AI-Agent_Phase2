  "resolved_question": "Among the 14 students previously identified as having high stress proxy (Low Satisfaction_Level) despite relatively low Daily_Usage_Hours (below the median of 3.2), which single factor appears to have the most impact or is most prominent?",
  "uses_prior_context": true,
  "follow_up_context": "Previous analysis identified 14 students using Low Satisfaction_Level as a proxy for high stress and Daily_Usage_Hours below 3.2 as relatively low hours. Summary counts for possible explanatory factors were: Impact_on_Grades = No Change 8, Slight Decline 3, Improved 3; Education_Level = College 7, School 6, University 1; Purpose = Writing 4, Research 4, Coding 3, Learning 2, Homework 1; AI_Tool_Used = Gemini 6, ChatGPT 3, Copilot 2, Grammarly 2, Notion AI 1.",
  "generated_code": "import pandas as pd\n\ndata = stored_result if isinstance(stored_result, dict) else {}\nfactors = data.get(\"possible_explanatory_factors\", {})\ntotal = data.get(\"count\")\n\nif not factors or not total:\n    result = \"Missing summary counts for the identified 14 students, so I can't determine the most prominent single factor from the stored result.\"\nelse:\n    top_candidates = []\n    for factor_name, counts in factors.items():\n        if isinstance(counts, dict) and counts:\n            top_category = max(counts.items(), key=lambda x: x[1])\n            top_candidates.append({\n                \"factor\": factor_name,\n                \"category\": top_category[0],\n                \"count\": int(top_category[1]),\n                \"share\": round(top_category[1] / total, 3)\n            })\n    if not top_candidates:\n        result = \"The stored result does not include usable factor counts to identify the most prominent factor.\"\n    else:\n        overall_top = max(top_candidates, key=lambda x: x[\"count\"])\n        explanation = (\n            f\"The single most prominent factor appears to be {overall_top['factor']} — specifically \"\n            f\"'{overall_top['category']}' ({overall_top['count']} of {total} students, \"\n            f\"{round(overall_top['share']*100, 1)}%). \"\n        )\n        if overall_top[\"factor\"] == \"Impact_on_Grades\" and overall_top[\"category\"] == \"No Change\":\n            explanation += (\n                \"This suggests the strongest common pattern among these low-usage but low-satisfaction students \"\n                \"is not worsening grades, but a lack of perceived academic payoff despite using AI, which may be \"\n                \"contributing to dissatisfaction/stress.\"\n            )\n        else:\n            explanation += \"It has the highest count among the summarized possible explanatory factors.\"\n        result = {\n            \"most_prominent_factor\": overall_top[\"factor\"],\n            \"most_common_category_within_factor\": overall_top[\"category\"],\n            \"count\": overall_top[\"count\"],\n            \"out_of_total\": int(total),\n            \"share\": overall_top[\"share\"],\n            \"answer\": explanation,\n            \"comparison_of_top_categories\": top_candidates\n        }",
