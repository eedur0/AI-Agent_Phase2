  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_order = {\n    'Significant Decline': 1,\n    'Declined': 2,\n    'Slight Decline': 3,\n    'No Change': 4,\n    'Slight Improvement': 5,\n    'Improved': 6,\n    'Significantly Improved': 7\n}\n\ndf['Impact_Score'] = df['Impact_on_Grades'].map(impact_order)\n\n# Group students by very similar daily usage (rounded to nearest 0.5 hour)\ndf['Usage_Group'] = (df['Daily_Usage_Hours'] * 2).round() / 2\n\npairs = []\nfor usage, group in df.groupby('Usage_Group'):\n    group = group.sort_values('Impact_Score')\n    if group['Impact_Score'].nunique() > 1:\n        low = group.iloc[0]\n        high = group.iloc[-1]\n        score_gap = int(high['Impact_Score'] - low['Impact_Score'])\n        if score_gap >= 2:\n            differing_factors = {}\n            for col in ['Age', 'Gender', 'Education_Level', 'City', 'AI_Tool_Used', 'Purpose', 'Satisfaction_Level']:\n                if low[col] != high[col]:\n                    differing_factors[col] = [low[col], high[col]]\n            pairs.append({\n                'similar_daily_usage_hours': float(usage),\n                'lower_performance_student': {\n                    'Student_ID': int(low['Student_ID']),\n                    'Impact_on_Grades': low['Impact_on_Grades'],\n                    'Age': int(low['Age']),\n                    'Gender': low['Gender'],\n                    'Education_Level': low['Education_Level'],\n                    'City': low['City'],\n                    'AI_Tool_Used': low['AI_Tool_Used'],\n                    'Purpose': low['Purpose'],\n                    'Satisfaction_Level': low['Satisfaction_Level']\n                },\n                'higher_performance_student': {\n                    'Student_ID': int(high['Student_ID']),\n                    'Impact_on_Grades': high['Impact_on_Grades'],\n                    'Age': int(high['Age']),\n                    'Gender': high['Gender'],\n                    'Education_Level': high['Education_Level'],\n                    'City': high['City'],\n                    'AI_Tool_Used': high['AI_Tool_Used'],\n                    'Purpose': high['Purpose'],\n                    'Satisfaction_Level': high['Satisfaction_Level']\n                },\n                'impact_score_gap': score_gap,\n                'potential_explanatory_factors': differing_factors\n            })\n\n# Summarize which factors most often differ in these contrasting pairs\nfactor_counts = {}\nfor p in pairs:\n    for factor in p['potential_explanatory_factors']:\n        factor_counts[factor] = factor_counts.get(factor, 0) + 1\n\nfactor_counts = dict(sorted(factor_counts.items(), key=lambda x: (-x[1], x[0])))\n\nresult = {\n    'contrasting_student_pairs_with_similar_study_time': pairs,\n    'summary': {\n        'total_pairs_found': len(pairs),\n        'most_common_potential_factors': factor_counts,\n        'interpretation': (\n            \"Students with similar Daily_Usage_Hours can still report very different Impact_on_Grades. \"\n            \"The differences in these pairs are most plausibly associated with variations in Purpose, \"\n            \"Satisfaction_Level, AI_Tool_Used, Education_Level, and other demographic/context fields where they differ. \"\n            \"Because the dataset does not include direct grades or detailed study habits, these are suggestive factors rather than causal proof.\"\n        )\n    }\n}",
