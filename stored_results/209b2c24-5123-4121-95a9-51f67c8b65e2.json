  "generated_code": "import pandas as pd\nimport numpy as np\n\ndf = pd.read_csv('/Users/ed/Documents/School/S26/ECE157C/ECE157C_272C_HW2/project/datasets/AI_Student_Life_Pakistan_2026.csv')\n\nimpact_order = {\n    'Significant Decline': 0,\n    'Declined': 1,\n    'Slight Decline': 2,\n    'No Change': 3,\n    'Improved': 4,\n    'Significantly Improved': 5\n}\n\nsatisfaction_order = {\n    'Low': 0,\n    'Medium': 1,\n    'High': 2\n}\n\ndf = df.copy()\ndf['Impact_Score'] = df['Impact_on_Grades'].map(impact_order)\ndf['Satisfaction_Score'] = df['Satisfaction_Level'].map(satisfaction_order)\n\n# Find students with very similar study/use time (same rounded to 0.1 hour)\npairs = []\nfor usage, group in df.groupby('Daily_Usage_Hours'):\n    if len(group) < 2:\n        continue\n    g = group.sort_values('Impact_Score')\n    rows = g.to_dict('records')\n    for i in range(len(rows)):\n        for j in range(i + 1, len(rows)):\n            diff = abs(rows[j]['Impact_Score'] - rows[i]['Impact_Score'])\n            if diff >= 2:\n                pairs.append({\n                    'Daily_Usage_Hours': float(usage),\n                    'Student_1_ID': int(rows[i]['Student_ID']),\n                    'Student_1_Impact': rows[i]['Impact_on_Grades'],\n                    'Student_1_Satisfaction': rows[i]['Satisfaction_Level'],\n                    'Student_1_Purpose': rows[i]['Purpose'],\n                    'Student_1_Education_Level': rows[i]['Education_Level'],\n                    'Student_1_AI_Tool': rows[i]['AI_Tool_Used'],\n                    'Student_1_City': rows[i]['City'],\n                    'Student_2_ID': int(rows[j]['Student_ID']),\n                    'Student_2_Impact': rows[j]['Impact_on_Grades'],\n                    'Student_2_Satisfaction': rows[j]['Satisfaction_Level'],\n                    'Student_2_Purpose': rows[j]['Purpose'],\n                    'Student_2_Education_Level': rows[j]['Education_Level'],\n                    'Student_2_AI_Tool': rows[j]['AI_Tool_Used'],\n                    'Student_2_City': rows[j]['City'],\n                    'Impact_Score_Difference': int(diff)\n                })\n\npairs_df = pd.DataFrame(pairs)\n\nif pairs_df.empty:\n    result = {\n        'similar_students': [],\n        'explanation': 'No student pairs were found with identical Daily_Usage_Hours and significantly different Impact_on_Grades based on the chosen ordinal mapping.'\n    }\nelse:\n    # Keep the most contrasting examples\n    pairs_df = pairs_df.sort_values(\n        ['Impact_Score_Difference', 'Daily_Usage_Hours'],\n        ascending=[False, True]\n    ).head(10)\n\n    factor_summaries = []\n    for _, row in pairs_df.iterrows():\n        differing_factors = []\n        for factor, c1, c2 in [\n            ('Purpose', 'Student_1_Purpose', 'Student_2_Purpose'),\n            ('Education_Level', 'Student_1_Education_Level', 'Student_2_Education_Level'),\n            ('AI_Tool_Used', 'Student_1_AI_Tool', 'Student_2_AI_Tool'),\n            ('Satisfaction_Level', 'Student_1_Satisfaction', 'Student_2_Satisfaction'),\n            ('City', 'Student_1_City', 'Student_2_City')\n        ]:\n            if row[c1] != row[c2]:\n                differing_factors.append({\n                    'factor': factor,\n                    'student_1': row[c1],\n                    'student_2': row[c2]\n                })\n        factor_summaries.append({\n            'Daily_Usage_Hours': float(row['Daily_Usage_Hours']),\n            'student_pair': [int(row['Student_1_ID']), int(row['Student_2_ID'])],\n            'performance_comparison': {\n                'student_1': row['Student_1_Impact'],\n                'student_2': row['Student_2_Impact']\n            },\n            'possible_explanatory_factors': differing_factors\n        })\n\n    # Aggregate which factors differ most often among contrasting pairs\n    factor_counts = {}\n    for item in factor_summaries:\n        for f in item['possible_explanatory_factors']:\n            factor_counts[f['factor']] = factor_counts.get(f['factor'], 0) + 1\n\n    result = {\n        'similar_students': factor_summaries,\n        'most_common_possible_factors': factor_counts,\n        'explanation': (\n            'Students were matched by identical Daily_Usage_Hours and flagged when their '\n            'Impact_on_Grades differed substantially using an ordinal score. The most plausible '\n            'explanations in this dataset are differences in Purpose of AI use, Satisfaction_Level, '\n            'Education_Level, AI_Tool_Used, and sometimes City. In particular, students using AI '\n            'for different purposes (such as learning vs. writing/coding/research) can show very '\n            'different grade outcomes even with the same usage time.'\n        )\n    }",
